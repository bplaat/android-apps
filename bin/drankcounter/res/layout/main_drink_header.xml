<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/DrinkButtonsContainer">

    <LinearLayout android:id="@+id/main_add_beer_button"
        style="@style/DrinkTypeButton">
        <ImageView
            android:src="@drawable/ic_glass_mug"
            android:contentDescription="@string/main_add_beer"
            style="@style/DrinkTypeButtonIcon" />
        <TextView android:id="@+id/main_beer_count"
            android:text="0"
            style="@style/DrinkTypeCounter" />
    </LinearLayout>

    <LinearLayout android:id="@+id/main_add_wine_button"
        style="@style/DrinkTypeButton">
        <ImageView
            android:src="@drawable/ic_glass_wine"
            android:contentDescription="@string/main_add_wine"
            style="@style/DrinkTypeButtonIcon" />
        <TextView android:id="@+id/main_wine_count"
            android:text="0"
            style="@style/DrinkTypeCounter" />
    </LinearLayout>

    <LinearLayout android:id="@+id/main_add_liqueur_button"
        style="@style/DrinkTypeButton">
        <ImageView
            android:src="@drawable/ic_cup"
            android:contentDescription="@string/main_add_liqueur"
            style="@style/DrinkTypeButtonIcon" />
        <TextView android:id="@+id/main_liqueur_count"
            android:text="0"
            style="@style/DrinkTypeCounter" />
    </LinearLayout>
</LinearLayout>
